{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "beyondcode/laravel-websockets": "^1.14",
        "dilovar-91/mango-office-api": "dev-master",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "haruncpi/laravel-user-activity": "^1.0",
        "http-interop/http-factory-guzzle": "^1.2",
        "intervention/image": "^2.7",
        "irazasyed/telegram-bot-sdk": "^3.4.1",
        "jenssegers/agent": "^2.6",
        "laravel-notification-channels/telegram": "^2.1",
        "laravel/framework": "^8.75",
        "laravel/sanctum": "^2.15",
        "laravel/scout": "^9.8",
        "laravel/tinker": "^2.5",
        "maatwebsite/excel": "^3.1",
        "meilisearch/meilisearch-php": "^1.7",
        "phpoffice/phpspreadsheet": "^1.29",
        "predis/predis": "^2.2",
        "propaganistas/laravel-phone": "^4.3",
        "pusher/pusher-php-server": "^7.2",
        "rap2hpoutre/laravel-log-viewer": "^2.2",
        "rappasoft/laravel-authentication-log": "^1.3",
        "silber/bouncer": "^1.0",
        "spatie/laravel-activitylog": "^3.17",
        "spatie/laravel-query-builder": "^4.0",
        "torann/geoip": "^3.0",
        "ext-json": "*"
    },
    "require-dev": {
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^5.10",
        "phpunit/phpunit": "^9.5.10"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/dilovar-91/mango-office-api"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
